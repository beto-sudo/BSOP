npx lint-staged

# La validación de SCHEMA_REF vs migraciones vive en CI
# (.github/workflows/schema-check.yml): regenera contra una shadow DB construida
# desde las migraciones, NO contra prod. El pre-commit ya no corre `schema:check`
# (el viejo, contra prod, fallaría aquí porque SCHEMA_REF ahora refleja la shadow).
# Tras tocar migraciones, regenerá local con `supabase start && npm run db:regen`
# y commiteá SCHEMA_REF.md + types/supabase.ts (ver supabase/GOVERNANCE.md §3).
if git diff --cached --name-only | grep -qE '^supabase/migrations/'; then
  echo "→ tocaste migraciones: regenerá los derivados con 'supabase start && npm run db:regen'"
  echo "  y commiteá supabase/SCHEMA_REF.md + types/supabase.ts (CI valida con schema-check)."
fi
